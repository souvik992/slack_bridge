# ──────────────────────────────────────────────────
# Slack App credentials
# ──────────────────────────────────────────────────

# Signing secret from your Slack App settings → Basic Information
SLACK_SIGNING_SECRET=your_slack_signing_secret_here

# Bot User OAuth Token (starts with xoxb-)
# Requires scopes: chat:write, commands
SLACK_BOT_TOKEN=xoxb-your-bot-token-here

# ──────────────────────────────────────────────────
# GitHub credentials
# ──────────────────────────────────────────────────

# Classic PAT or fine-grained token with:
#   - repo:  read (for fine-grained)
#   - actions: write (repository_dispatch needs "Contents: write" for fine-grained)
GITHUB_PERSONAL_ACCESS_TOKEN=ghp_your_pat_here

# e.g. "my-org"  or your GitHub username
GITHUB_REPO_OWNER=your_github_org_or_username

# e.g. "my-playwright-repo"
GITHUB_REPO_NAME=your_repo_name

# ──────────────────────────────────────────────────
# Results webhook secret (shared with GitHub Actions)
# ──────────────────────────────────────────────────

# Any strong random string. GitHub Actions sends this in the
# Authorization header when posting test results back.
# Generate: openssl rand -hex 32
RESULTS_WEBHOOK_SECRET=your_results_webhook_secret_here

# ──────────────────────────────────────────────────
# Server
# ──────────────────────────────────────────────────
PORT=3000
